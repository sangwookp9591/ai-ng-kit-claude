{
  "name": "ai-ng-kit-claude",
  "version": "2.8.4",
  "type": "module",
  "description": "Harness Engineering Agent for Claude Code — 14 named agents, 4-tier review pipeline, 7-step ship workflow, CSO security audit, AI slop detection, autoplan engine",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sangwookp9591/ai-ng-kit-claude.git"
  },
  "homepage": "https://github.com/sangwookp9591/ai-ng-kit-claude#readme",
  "keywords": [
    "claude-code",
    "ai-agents",
    "aing",
    "harness",
    "pdca",
    "tdd",
    "team-pipeline",
    "multi-agent"
  ],
  "author": "sangwookp9591",
  "scripts": {
    "build": "tsc && npm run build:skills",
    "build:ts": "tsc",
    "build:skills": "node dist/scripts/build/gen-skill-docs.js",
    "build:all": "node dist/scripts/build/generate-all.js",
    "build:check": "node dist/scripts/build/generate-all.js --check",
    "build:force": "node dist/scripts/build/generate-all.js --force",
    "check:skills": "node dist/scripts/build/check-freshness.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/**/*.test.ts",
    "test:e2e": "EVALS=1 node --test tests/e2e/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "agents/",
    "skills/",
    "hooks/",
    "dist/",
    "browse/dist/",
    "templates/",
    "images/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.0"
  }
}
